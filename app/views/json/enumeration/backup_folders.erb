"backup_folders": {
<% unless @backup_folders.empty? -%>
<% last_index = @backup_folders.size - 1 -%>
<% @backup_folders.each_with_index do |backup_folder, index| -%>
  <%= backup_folder.url.to_json %>: {
    "plugin_name": <%= backup_folder.plugin_name.to_json %>,
    "severity": <%= backup_folder.severity.to_json %>,
    "response_code": <%= backup_folder.response_code.to_json %>,
    <% if backup_folder.interesting_entries && !backup_folder.interesting_entries.empty? -%>
    "directory_listing_enabled": true,
    "entries": <%= backup_folder.interesting_entries.to_json %>,
    <% else -%>
    "directory_listing_enabled": false,
    <% end -%>
    <%= render('@finding', item: backup_folder) -%>
  }<% unless index == last_index -%>,<% end -%>
<% end -%>
<% end -%>
},